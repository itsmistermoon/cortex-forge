filters:
  and:
    - file.inFolder("wiki/pages")
    - file.name != "_index"
properties:
  status:
    displayName: Estado
  repo:
    displayName: Repo
  updated:
    displayName: Actualizado
  tags:
    displayName: Tags
views:
  - type: table
    name: Activos
    filters:
      and:
        - status = "active"
    order:
      - file.name
      - status
      - repo
      - updated
  - type: table
    name: Todos
    order:
      - file.name
      - status
      - repo
      - updated
